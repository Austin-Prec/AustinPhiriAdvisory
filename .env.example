# Copy this file to .env for local development.
#
# These come from the SAME Supabase project you already use for the
# contact form on this site (the one with the contact_messages table
# and the contact Edge Function). You do not need a new project.
#
# Find these values at: https://supabase.com/dashboard → your project →
# Project Settings → API.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# On Cloudflare Pages, set these same two variables under:
# Workers & Pages → your project → Settings → Environment variables
# (add them for both Production and Preview), then trigger a redeploy.
